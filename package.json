{
  "name": "opencode-sharp",
  "version": "0.1.0",
  "description": "opencode plugin that adds focused Roslyn-backed C# tools.",
  "type": "module",
  "module": "dist/index.js",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adamhathcock/opencode-sharp.git"
  },
  "bugs": {
    "url": "https://github.com/adamhathcock/opencode-sharp/issues"
  },
  "homepage": "https://github.com/adamhathcock/opencode-sharp#readme",
  "keywords": [
    "opencode",
    "plugin",
    "csharp",
    "roslyn",
    "lsp"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "dev": "tsc --watch",
    "prepack": "bun run build",
    "test": "bun test",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@opencode-ai/plugin": "latest"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "latest",
    "prettier": "^3.8.3",
    "typescript": "latest"
  }
}
